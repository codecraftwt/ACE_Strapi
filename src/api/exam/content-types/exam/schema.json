{
  "kind": "collectionType",
  "collectionName": "exams",
  "info": {
    "singularName": "exam",
    "pluralName": "exams",
    "displayName": "Exam"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "examName": {
      "type": "string"
    },
    "examTiype": {
      "type": "enumeration",
      "enum": [
        "Unit Test ",
        "Internal",
        "Semester Exam"
      ]
    },
    "Semester": {
      "type": "enumeration",
      "enum": [
        "Semester 1",
        "Semester 2",
        "Semester 3",
        "Semester 4",
        "Semester 5",
        "Semester 6 ",
        "Semester 7",
        "Semester 8"
      ]
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course"
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department"
    },
    "subjects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::subject.subject",
      "mappedBy": "exams"
    },
    "Examstatus": {
      "type": "enumeration",
      "enum": [
        "Draft",
        "Published",
        "Completed"
      ]
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "TestDate": {
      "type": "date"
    },
    "TestTime": {
      "type": "time"
    }
  }
}
