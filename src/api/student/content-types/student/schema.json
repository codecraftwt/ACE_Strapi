{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "student"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Address": {
      "type": "string",
      "required": true
    },
    "Phone": {
      "type": "string",
      "required": true,
      "regex": "^[0-9]{10}$"
    },
    "Email": {
      "type": "string",
      "required": true
    },
    "message": {
      "type": "text"
    },
    "department": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::department.department"
    },
    "course": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::course.course"
    },
    "send_email": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::send-email.send-email",
      "inversedBy": "students"
    },
    "accessDepartmentKey": {
      "type": "string"
    },
    "results": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::result.result",
      "mappedBy": "student"
    }
  }
}
